{
  "compilerOptions": {
    "target": "ES6",
    "lib": ["ES2015", "DOM"],
    "moduleResolution": "node",
    "module": "esnext",
    "baseUrl": "./",
    "paths": {
      "@/*": ["./src/*"]
    },
    "allowSyntheticDefaultImports": true,
    "jsx": "preserve",
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "src/declare/pdb.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "noImplicitAny": false,
  "allowJs": true,
}
