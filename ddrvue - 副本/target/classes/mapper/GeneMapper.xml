<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.database_ddr_springboot.mapper.GeneMapper">

    <update id="update">
        update gene
        <set>
            <trim prefixOverrides=",">
                <if test="gene_name != null">
                    gene_name = #{gene_name},
                </if>
                <if test="pathways != null">
                    pathways = #{pathways},
                </if>
                <if test="species != null">
                    species = #{species},
                </if>
                <if test="title != null">
                    title = #{title},
                </if>
                <if test="doi != null">
                    doi = #{doi}
                </if>
            </trim>
        </set>
        <where>
            id = #{id}
        </where>
    </update>
</mapper>